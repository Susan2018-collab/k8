pipeline {
    agent any

    environment {
        IMAGE_NAME = "monitoring-app"
        TAG = "v1.${BUILD_NUMBER}"
        REGISTRY = "docker.io/library"
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    docker build -t ${IMAGE_NAME}:${TAG} projects/monitoring-app
                """
            }
        }

        stage('Update Helm Chart') {
            steps {
                sh """
                    sed -i 's/tag:.*/tag: ${TAG}/g' projects/nginx-chart/values.yaml
                """
            }
        }

        stage('Commit & Push Changes (GitOps)') {
            steps {
                sh """
                    git config user.email "jenkins@example.com"
                    git config user.name "jenkins"

                    git add projects/nginx-chart/values.yaml
                    git commit -m "Updated image tag to ${TAG}" || echo "No changes to commit"
                    git push https://github.com/Susan2018-collab/k8.git HEAD:main
                """
            }
        }
    }

    post {
        success {
            echo "Pipeline SUCCESS"
        }
        failure {
            echo "Pipeline FAILED"
        }
    }
}
